<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Enterprise Automation Suite" parallel="tests" thread-count="2">

    <test name="Chrome Test Execution">
		<parameter name="browser" value="chrome" />
        <classes>
			<class name="tests.LoginTest" />
			<class name="tests.DashboardTest" />
			<class name="tests.AdminTest" />
			<class name="tests.PIMTest" />
			<class name="tests.LeaveTest" />
			<class name="tests.RecruitmentTest" />
			<class name="tests.MyInfoTest" />
            <class name="tests.TimeTest" />
            <class name="tests.SecurityTest" />
            <class name="tests.UITest" />
            <class name="tests.SystemTest" />
        </classes>
    </test>

    <test name="Edge Test Execution">
		<parameter name="browser" value="edge" />
        <classes>
			<class name="tests.LoginTest" />
			<class name="tests.DashboardTest" />
			<class name="tests.AdminTest" />
			<class name="tests.PIMTest" />
			<class name="tests.LeaveTest" />
			<class name="tests.RecruitmentTest" />
			<class name="tests.MyInfoTest" />
            <class name="tests.TimeTest" />
            <class name="tests.SecurityTest" />
            <class name="tests.UITest" />
            <class name="tests.SystemTest" />
        </classes>
    </test>

</suite>